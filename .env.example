# --- Local development ---
# Path to the Google service-account credentials JSON file.
GOOGLE_CREDENTIALS_FILE=C:\Users\Oduor\Downloads\JSON Files\reporting-488611-05bb9568ffb8.json

PORT=5050
FLASK_DEBUG=1

# --- Vercel / production ---
# Vercel's filesystem is read-only and ephemeral, so GOOGLE_CREDENTIALS_FILE
# doesn't work there. Instead, set GOOGLE_CREDENTIALS_JSON in the Vercel
# project's Environment Variables (Settings -> Environment Variables) to the
# ENTIRE contents of the service-account JSON key file, minified to one line.
# If GOOGLE_CREDENTIALS_JSON is set, it takes precedence over
# GOOGLE_CREDENTIALS_FILE, so nothing else in this file needs to change.
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...", ...}
#
# Leave FLASK_DEBUG unset (or "0") on Vercel - debug mode should never run in
# production. PORT is unused there (Vercel manages the listening port itself).

SPREADSHEET_ID=1S4kRCl1KWMTWKaSF8NSIXjDiJmvREzv7hm4vDnowdqs
